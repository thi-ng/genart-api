{
	"name": "@example/param-editors",
	"version": "0.0.1",
	"description": "Example GenArt API param editor GUIs",
	"repository": "https://github.com/thi-ng/genart-api",
	"author": "Karsten Schmidt (https://thi.ng)",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"css:watch": "../../node_modules/.bin/metacss develop --bundle --watch --pretty --out-specs css/framework.json --out-css css/style.css --force @css/includes.txt ../../node_modules/@thi.ng/meta-css/specs/*.mcss.json css/*.mcss.json css/*.mcss",
		"css:build": "../../node_modules/.bin/metacss develop --bundle --out-specs css/framework.json --out-css css/style.css --force @css/includes.txt ../../node_modules/@thi.ng/meta-css/specs/*.mcss.json css/*.mcss.json css/*.mcss",
		"start": "yarn css:build && yarn start:only",
		"start:only": "yarn build:prepare && vite --host --port 8080 --open",
		"dev": "mprocs 'yarn css:watch' 'yarn start:only'",
		"build:prepare": "node tools/inject-version.js",
		"build": "yarn css:build && yarn build:prepare && tsc && vite build --base='./'",
		"preview": "vite preview --host --open"
	},
	"devDependencies": {
		"@thi.ng/meta-css": "^0.19.24",
		"typescript": "^5.9.2",
		"vite": "^7.1.4",
		"vite-plugin-html": "^3.2.2"
	},
	"dependencies": {
		"@genart-api/core": "workspace:^",
		"@thi.ng/api": "^8.12.2",
		"@thi.ng/arrays": "^2.13.11",
		"@thi.ng/canvas": "^1.0.23",
		"@thi.ng/checks": "^3.7.18",
		"@thi.ng/color": "^5.7.59",
		"@thi.ng/compare": "^2.4.28",
		"@thi.ng/date": "^2.7.64",
		"@thi.ng/defmulti": "^3.0.76",
		"@thi.ng/equiv": "^2.1.92",
		"@thi.ng/hex": "^2.3.80",
		"@thi.ng/hiccup-canvas": "^3.1.74",
		"@thi.ng/hiccup-html": "^2.7.34",
		"@thi.ng/imgui": "^3.2.43",
		"@thi.ng/layout": "^4.0.6",
		"@thi.ng/math": "^5.12.0",
		"@thi.ng/mime": "^2.7.18",
		"@thi.ng/pixel": "^7.5.10",
		"@thi.ng/ramp": "^3.3.57",
		"@thi.ng/rdom": "^1.7.57",
		"@thi.ng/rdom-forms": "^1.0.41",
		"@thi.ng/rstream": "^9.2.40",
		"@thi.ng/strings": "^3.9.22",
		"@thi.ng/transducers": "^9.6.9",
		"@thi.ng/transducers-stats": "^2.2.39"
	}
}
